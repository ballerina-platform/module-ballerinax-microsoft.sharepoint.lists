    boolean dollarCount?;
    # Select properties to be returned
    @http:Query {name: "$select"}
    ("id"|"access"|"create"|"delete"|"edit"|"endDateTime"|"incompleteData"|"isTrending"|"move"|"startDateTime"|"activities")[] dollarSelect?;
};

