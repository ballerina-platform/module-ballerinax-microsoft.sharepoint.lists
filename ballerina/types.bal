# Request body schema for creating a sharing link for a SharePoint list item.
public type ListItemIdMicrosoftGraphCreateLinkBody record {
    # ISO 8601 UTC datetime at which the sharing link expires.
    string? expirationDateTime?;
    # Optional password to protect access to the sharing link.
    string? password?;
    # List of recipients to whom the sharing link will be granted.
    MicrosoftGraphDriveRecipient[] recipients?;
    # The scope of the sharing link, such as anonymous, organization, or specific users.
    string? scope?;
    # Indicates whether an email notification is sent to recipients. Defaults to false.
    boolean? sendNotification = false;
    # The type of sharing link to create, such as view, edit, or embed.
    string? 'type?;
    # Optional message included in the sharing notification sent to recipients.
    string? message?;
    # Indicates whether inherited permissions are retained on the link. Defaults to false.
    boolean? retainInheritedPermissions = false;
};

